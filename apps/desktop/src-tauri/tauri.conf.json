{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timebox",
  "version": "0.1.0",
  "identifier": "com.brutaldisco.timebox",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run web:dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm --prefix ../.. run desktop:web:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/icon.png"
    ]
  }
}
